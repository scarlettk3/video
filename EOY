Features:
  1. OpenFlow 1.3 support
  2. MAC learning + L2 forwarding (like simple_switch_13)
  3. Idle timeout = 10 seconds (as per your procedure)
  4. Default flow reinstall after idle timeout
  5. Per-flow statistics collection every 5 seconds
  6. Packet-In rate monitoring (Flow-Rule Saturation detection)
  7. Flow count monitoring per switch (TCAM exhaustion detection)
  8. LLDP packet logging (Topology Poisoning detection)
  9. All stats logged to /tmp/controller_stats.log
=============================================================================
"""

from os_ken.base import app_manager
from os_ken.controller import ofp_event
from os_ken.controller.handler import (
    CONFIG_DISPATCHER,
    MAIN_DISPATCHER,
    DEAD_DISPATCHER,
    set_ev_cls
)
from os_ken.ofproto import ofproto_v1_3
from os_ken.lib.packet import (
    packet,
    ethernet,
    ipv4,
    ipv6,
    tcp,
    udp,
    icmp,
    ether_types
)
from os_ken.lib import hub
from os_ken.topology import event as topo_event
from os_ken.topology.api import get_switch, get_link

import time
import collections
import logging
import os

# ── Logging Setup ──────────────────────────────────────────────────────────
LOG_FILE = "/tmp/controller_stats.log"
logging.basicConfig(
    level=logging.INFO,
    format='%(asctime)s [%(levelname)s] %(message)s',
    handlers=[
        logging.FileHandler(LOG_FILE),
        logging.StreamHandler()
    ]
)
logger = logging.getLogger("LFA_Controller")


class LFAController(app_manager.OSKenApp):
    """
    Custom SDN controller for LFA detection research.
    Handles Fat-Tree k=4 topology with 20 switches and 16 hosts.
    """

    OFP_VERSIONS = [ofproto_v1_3.OFP_VERSION]

    # ── Your Fat-Tree switch names ─────────────────────────────────
    FAT_TREE_SWITCHES = [
        'c1', 'c2', 'c3', 'c4',           # Core
        'a11','a12','a21','a22',           # Aggregation pod 1,2
        'a31','a32','a41','a42',           # Aggregation pod 3,4
        'e11','e12','e21','e22',           # Edge pod 1,2
        'e31','e32','e41','e42',           # Edge pod 3,4
    ]

    # ── Your Fat-Tree host IPs ─────────────────────────────────────
    HOST_IPS = [
        "10.0.0.1","10.0.0.2","10.0.1.1","10.0.1.2",
        "10.1.0.1","10.1.0.2","10.1.1.1","10.1.1.2",
        "10.2.0.1","10.2.0.2","10.2.1.1","10.2.1.2",
        "10.3.0.1","10.3.0.2","10.3.1.1","10.3.1.2",
    ]

    def __init__(self, *args, **kwargs):
        super(LFAController, self).__init__(*args, **kwargs)

        # ── MAC learning table: {dpid: {mac: port}} ───────────────
        self.mac_to_port = {}

        # ── Datapath registry: {dpid: datapath} ───────────────────
        self.datapaths = {}

        # ── Packet-In counters: {dpid: count} ─────────────────────
        self.pkt_in_count = collections.defaultdict(int)

        # ── Per-switch flow counts: {dpid: count} ─────────────────
        self.flow_counts = collections.defaultdict(int)

        # ── Traffic stats: {dpid: {cookie: (bytes, packets)}} ─────
        self.flow_stats = collections.defaultdict(dict)

        # ── LLDP injection counter (Topology Poisoning detection) ──
        self.lldp_count = collections.defaultdict(int)

        # ── Timestamps ────────────────────────────────────────────
        self.start_time = time.time()
        self.last_stats_time = time.time()

        # ── Thresholds for anomaly logging ────────────────────────
        self.PKT_IN_THRESHOLD  = 1000   # packet-ins/interval → saturation alert
        self.FLOW_CNT_THRESHOLD = 800   # flows per switch    → TCAM alert
        self.LLDP_THRESHOLD     = 50    # LLDP frames/interval→ poison alert

        # ── Idle timeout (10s as per your procedure) ───────────────
        self.IDLE_TIMEOUT = 10
        self.HARD_TIMEOUT = 0           # no hard timeout

        # ── Start background monitoring thread ────────────────────
        self.monitor_thread = hub.spawn(self._monitor_loop)

        logger.info("=" * 60)
        logger.info("LFA Controller started")
        logger.info(f"Idle timeout  : {self.IDLE_TIMEOUT}s")
        logger.info(f"Log file      : {LOG_FILE}")
        logger.info(f"PKT-IN thresh : {self.PKT_IN_THRESHOLD}")
        logger.info(f"Flow thresh   : {self.FLOW_CNT_THRESHOLD}")
        logger.info("=" * 60)

    # =========================================================
    #  SWITCH CONNECT / DISCONNECT
    # =========================================================

    @set_ev_cls(ofp_event.EventOFPSwitchFeatures, CONFIG_DISPATCHER)
    def switch_features_handler(self, ev):
        """
        Called when a switch connects.
        Installs the default table-miss flow (priority=0)
        as per your procedure.
        """
        datapath = ev.msg.datapath
        ofproto  = datapath.ofproto
        parser   = datapath.ofproto_parser
        dpid     = datapath.id

        self.datapaths[dpid] = datapath
        self.mac_to_port.setdefault(dpid, {})

        logger.info(f"[+] Switch connected: dpid={dpid:#010x}")

        # ── Install table-miss flow (priority=0) ──────────────────
        # Sends all unmatched packets to controller
        # permanent — idle_timeout=0 so it survives the 10s timeout
        match   = parser.OFPMatch()
        actions = [
            parser.OFPActionOutput(
                ofproto.OFPP_CONTROLLER,
                ofproto.OFPCML_NO_BUFFER
            )
        ]
        self._add_flow(
            datapath,
            priority=0,
            match=match,
            actions=actions,
            idle_timeout=0,    # permanent default flow
            hard_timeout=0
        )
        logger.info(f"    Default flow installed on dpid={dpid:#010x}")

    @set_ev_cls(ofp_event.EventOFPStateChange,
                [MAIN_DISPATCHER, DEAD_DISPATCHER])
    def state_change_handler(self, ev):
        """Track switch connect/disconnect."""
        datapath = ev.datapath
        dpid     = datapath.id
        if ev.state == MAIN_DISPATCHER:
            self.datapaths[dpid] = datapath
            logger.info(f"[+] Switch ACTIVE : dpid={dpid:#010x}")
        elif ev.state == DEAD_DISPATCHER:
            self.datapaths.pop(dpid, None)
            logger.info(f"[-] Switch REMOVED: dpid={dpid:#010x}")

    # =========================================================
    #  PACKET-IN HANDLER
    # =========================================================

    @set_ev_cls(ofp_event.EventOFPPacketIn, MAIN_DISPATCHER)
    def packet_in_handler(self, ev):
        """
        Main packet handler:
          1. Count Packet-Ins (Flow-Rule Saturation detection)
          2. Handle LLDP (Topology Poisoning detection)
          3. MAC learning
          4. Install flow rules with idle_timeout=10s
          5. Forward packet
        """
        msg      = ev.msg
        datapath = msg.datapath
        ofproto  = datapath.ofproto
        parser   = datapath.ofproto_parser
        dpid     = datapath.id
        in_port  = msg.match['in_port']

        # ── 1. Count Packet-Ins ───────────────────────────────────
        self.pkt_in_count[dpid] += 1

        # Alert on high Packet-In rate (Flow-Rule Saturation sign)
        if self.pkt_in_count[dpid] % self.PKT_IN_THRESHOLD == 0:
            elapsed = time.time() - self.start_time
            rate    = self.pkt_in_count[dpid] / elapsed
            logger.warning(
                f"[!] HIGH PKT-IN RATE on dpid={dpid:#010x}: "
                f"{self.pkt_in_count[dpid]:,} total | "
                f"{rate:.0f}/s avg — "
                f"POSSIBLE FLOW-RULE SATURATION LFA!"
            )

        # ── 2. Parse packet ───────────────────────────────────────
        pkt     = packet.Packet(msg.data)
        eth_pkt = pkt.get_protocol(ethernet.ethernet)

        if eth_pkt is None:
            return

        eth_type = eth_pkt.ethertype
        dst_mac  = eth_pkt.dst
        src_mac  = eth_pkt.src

        # ── 3. LLDP detection (Topology Poisoning) ────────────────
        if eth_type == ether_types.ETH_TYPE_LLDP:
            self.lldp_count[dpid] += 1
            if self.lldp_count[dpid] % self.LLDP_THRESHOLD == 0:
                logger.warning(
                    f"[!] HIGH LLDP RATE on dpid={dpid:#010x}: "
                    f"{self.lldp_count[dpid]} frames — "
                    f"POSSIBLE TOPOLOGY POISONING LFA!"
                )
            return  # Do not forward LLDP — drop it

        # ── 4. MAC learning ───────────────────────────────────────
        self.mac_to_port[dpid][src_mac] = in_port

        # Determine output port
        if dst_mac in self.mac_to_port[dpid]:
            out_port = self.mac_to_port[dpid][dst_mac]
        else:
            out_port = ofproto.OFPP_FLOOD

        actions = [parser.OFPActionOutput(out_port)]

        # ── 5. Install flow rule (idle_timeout=10s) ───────────────
        if out_port != ofproto.OFPP_FLOOD:
            ip_pkt  = pkt.get_protocol(ipv4.ipv4)
            ip6_pkt = pkt.get_protocol(ipv6.ipv6)

            if ip_pkt:
                # IP packet — match on 5-tuple for LFA analysis
                tp_pkt = (pkt.get_protocol(tcp.tcp) or
                          pkt.get_protocol(udp.udp))

                if tp_pkt and hasattr(tp_pkt, 'src_port'):
                    # TCP/UDP — full 5-tuple match
                    proto_num = (6 if pkt.get_protocol(tcp.tcp)
                                 else 17)
                    match = parser.OFPMatch(
                        in_port=in_port,
                        eth_type=ether_types.ETH_TYPE_IP,
                        ipv4_src=ip_pkt.src,
                        ipv4_dst=ip_pkt.dst,
                        ip_proto=proto_num
                    )
                else:
                    # ICMP or other IP
                    match = parser.OFPMatch(
                        in_port=in_port,
                        eth_type=ether_types.ETH_TYPE_IP,
                        ipv4_src=ip_pkt.src,
                        ipv4_dst=ip_pkt.dst
                    )
            else:
                # Non-IP — match on MAC
                match = parser.OFPMatch(
                    in_port=in_port,
                    eth_dst=dst_mac,
                    eth_src=src_mac
                )

            # Install with IDLE_TIMEOUT=10s
            # Flow expires after 10s of inactivity
            # Controller then reinstalls default flow
            self._add_flow(
                datapath,
                priority=1,
                match=match,
                actions=actions,
                idle_timeout=self.IDLE_TIMEOUT,
                hard_timeout=self.HARD_TIMEOUT
            )

        # ── 6. Send packet out ────────────────────────────────────
        data = None
        if msg.buffer_id == ofproto.OFP_NO_BUFFER:
            data = msg.data

        out = parser.OFPPacketOut(
            datapath=datapath,
            buffer_id=msg.buffer_id,
            in_port=in_port,
            actions=actions,
            data=data
        )
        datapath.send_msg(out)

    # =========================================================
    #  FLOW REMOVED HANDLER
    #  Reinstalls default flow after idle timeout expires
    # =========================================================

    @set_ev_cls(ofp_event.EventOFPFlowRemoved, MAIN_DISPATCHER)
    def flow_removed_handler(self, ev):
        """
        Called when a flow expires (idle timeout = 10s).
        Reinstalls the default table-miss flow automatically.
        This implements your procedure:
        'when idle timeout expires, controller reinstalls default flows'
        """
        msg      = ev.msg
        datapath = msg.datapath
        dpid     = datapath.id
        reason   = msg.reason
        ofproto  = datapath.ofproto

        reason_str = {
            ofproto.OFPRR_IDLE_TIMEOUT : "IDLE_TIMEOUT",
            ofproto.OFPRR_HARD_TIMEOUT : "HARD_TIMEOUT",
            ofproto.OFPRR_DELETE       : "DELETE",
            ofproto.OFPRR_GROUP_DELETE : "GROUP_DELETE",
        }.get(reason, "UNKNOWN")

        if reason == ofproto.OFPRR_IDLE_TIMEOUT:
            logger.debug(
                f"[~] Flow expired (IDLE_TIMEOUT) on "
                f"dpid={dpid:#010x} | "
                f"pkts={msg.packet_count} | "
                f"bytes={msg.byte_count}"
            )
            # Reinstall default table-miss flow
            self._reinstall_default_flow(datapath)

    def _reinstall_default_flow(self, datapath):
        """
        Reinstall priority=0 table-miss flow after expiry.
        As per your procedure:
        'sudo ovs-ofctl add-flow {sw} priority=0,actions=CONTROLLER:65535'
        """
        ofproto = datapath.ofproto
        parser  = datapath.ofproto_parser
        match   = parser.OFPMatch()
        actions = [
            parser.OFPActionOutput(
                ofproto.OFPP_CONTROLLER,
                ofproto.OFPCML_NO_BUFFER
            )
        ]
        self._add_flow(
            datapath,
            priority=0,
            match=match,
            actions=actions,
            idle_timeout=0,
            hard_timeout=0
        )

    # =========================================================
    #  FLOW STATS REPLY
    # =========================================================

    @set_ev_cls(ofp_event.EventOFPFlowStatsReply, MAIN_DISPATCHER)
    def flow_stats_reply_handler(self, ev):
        """
        Receive flow stats from switches.
        Monitors for TCAM exhaustion (Flow-Rule Saturation LFA).
        """
        dpid       = ev.msg.datapath.id
        flows      = ev.msg.body
        flow_count = len(flows)

        self.flow_counts[dpid] = flow_count

        # Alert if TCAM near saturation
        if flow_count > self.FLOW_CNT_THRESHOLD:
            logger.warning(
                f"[!] TCAM SATURATION on dpid={dpid:#010x}: "
                f"{flow_count} flows installed — "
                f"POSSIBLE FLOW-RULE SATURATION LFA!"
            )

        # Log per-flow stats
        total_bytes = 0
        total_pkts  = 0
        for flow in flows:
            total_bytes += flow.byte_count
            total_pkts  += flow.packet_count

        logger.debug(
            f"[STATS] dpid={dpid:#010x} | "
            f"flows={flow_count} | "
            f"bytes={total_bytes:,} | "
            f"pkts={total_pkts:,}"
        )

    # =========================================================
    #  PORT STATS REPLY
    # =========================================================

    @set_ev_cls(ofp_event.EventOFPPortStatsReply, MAIN_DISPATCHER)
    def port_stats_reply_handler(self, ev):
        """
        Receive port stats.
        Monitors for bandwidth flooding (Traditional/Slice LFA).
        """
        dpid = ev.msg.datapath.id
        for stat in ev.msg.body:
            if stat.port_no == ev.msg.datapath.ofproto.OFPP_LOCAL:
                continue
            rx_bytes = stat.rx_bytes
            tx_bytes = stat.tx_bytes
            rx_pkts  = stat.rx_packets
            tx_pkts  = stat.tx_packets
            rx_err   = stat.rx_errors
            tx_err   = stat.tx_errors

            # Log high traffic ports
            if rx_pkts > 10000 or tx_pkts > 10000:
                logger.info(
                    f"[PORT] dpid={dpid:#010x} "
                    f"port={stat.port_no} | "
                    f"rx={rx_pkts:,}pkts/{rx_bytes:,}B | "
                    f"tx={tx_pkts:,}pkts/{tx_bytes:,}B | "
                    f"err={rx_err+tx_err}"
                )

    # =========================================================
    #  BACKGROUND MONITOR LOOP
    # =========================================================

    def _monitor_loop(self):
        """
        Background thread: requests stats from all switches
        every 5 seconds. Logs summary every 30 seconds.
        """
        report_interval = 30
        last_report     = time.time()

        while True:
            hub.sleep(5)

            # Request stats from all connected switches
            for dpid, datapath in list(self.datapaths.items()):
                self._request_flow_stats(datapath)
                self._request_port_stats(datapath)

            # Print summary every 30 seconds
            now = time.time()
            if now - last_report >= report_interval:
                self._print_summary()
                last_report = now

    def _request_flow_stats(self, datapath):
        """Send OFPFlowStatsRequest to a switch."""
        parser = datapath.ofproto_parser
        req    = parser.OFPFlowStatsRequest(datapath)
        datapath.send_msg(req)

    def _request_port_stats(self, datapath):
        """Send OFPPortStatsRequest to a switch."""
        ofproto = datapath.ofproto
        parser  = datapath.ofproto_parser
        req     = parser.OFPPortStatsRequest(
            datapath, 0, ofproto.OFPP_ANY
        )
        datapath.send_msg(req)

    def _print_summary(self):
        """Print controller summary to log."""
        elapsed    = time.time() - self.start_time
        total_pkts = sum(self.pkt_in_count.values())
        total_lldp = sum(self.lldp_count.values())

        logger.info("=" * 60)
        logger.info(f"[SUMMARY] Uptime={elapsed:.0f}s | "
                    f"Switches={len(self.datapaths)}")
        logger.info(f"[SUMMARY] Total Pkt-In={total_pkts:,} | "
                    f"LLDP={total_lldp:,}")

        for dpid in self.datapaths:
            logger.info(
                f"  dpid={dpid:#010x} | "
                f"Pkt-In={self.pkt_in_count[dpid]:,} | "
                f"Flows={self.flow_counts[dpid]} | "
                f"LLDP={self.lldp_count[dpid]}"
            )
        logger.info("=" * 60)

    # =========================================================
    #  HELPER — ADD FLOW
    # =========================================================

    def _add_flow(self, datapath, priority, match, actions,
                  idle_timeout=10, hard_timeout=0, cookie=0):
        """
        Install a flow rule on a switch.
        Default idle_timeout=10s as per your procedure.
        """
        ofproto = datapath.ofproto
        parser  = datapath.ofproto_parser

        inst = [
            parser.OFPInstructionActions(
                ofproto.OFPIT_APPLY_ACTIONS,
                actions
           bh  )
        ]

        mod = parser.OFPFlowMod(
            datapath=datapath,
            cookie=cookie,
            priority=priority,
            idle_timeout=idle_timeout,
            hard_timeout=hard_timeout,
            flags=ofproto.OFPFF_SEND_FLOW_REM,  # notify on removal
            match=match,
            instructions=inst
        )
        datapath.send_msg(mod)





