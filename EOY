@set_ev_cls(ofp_event.EventOFPPacketIn, MAIN_DISPATCHER)
    def packet_in_handler(self, ev):
        """
        Main packet handler:
          1. Count Packet-Ins (Flow-Rule Saturation detection)
          2. Handle LLDP (Topology Poisoning detection)
          3. MAC learning
          4. Install flow rules with idle_timeout=10s
          5. Forward packet
        """
        msg      = ev.msg
        datapath = msg.datapath
        ofproto  = datapath.ofproto
        parser   = datapath.ofproto_parser
        dpid     = datapath.id
        in_port  = msg.match['in_port']

        # ── 1. Count Packet-Ins ───────────────────────────────────
        self.pkt_in_count[dpid] += 1

        # Alert on high Packet-In rate (Flow-Rule Saturation sign)
        if self.pkt_in_count[dpid] % self.PKT_IN_THRESHOLD == 0:
            elapsed = time.time() - self.start_time
            rate    = self.pkt_in_count[dpid] / elapsed
            logger.warning(
                f"[!] HIGH PKT-IN RATE on dpid={dpid:#010x}: "
                f"{self.pkt_in_count[dpid]:,} total | "
                f"{rate:.0f}/s avg — "
                f"POSSIBLE FLOW-RULE SATURATION LFA!"
            )

        # ── 2. Parse packet ───────────────────────────────────────
        pkt     = packet.Packet(msg.data)
        eth_pkt = pkt.get_protocol(ethernet.ethernet)

        if eth_pkt is None:
            return

        eth_type = eth_pkt.ethertype
        dst_mac  = eth_pkt.dst
        src_mac  = eth_pkt.src

        # ── 3. LLDP detection (Topology Poisoning) ────────────────
        if eth_type == ether_types.ETH_TYPE_LLDP:
            self.lldp_count[dpid] += 1
            if self.lldp_count[dpid] % self.LLDP_THRESHOLD == 0:
                logger.warning(
                    f"[!] HIGH LLDP RATE on dpid={dpid:#010x}: "
                    f"{self.lldp_count[dpid]} frames — "
                    f"POSSIBLE TOPOLOGY POISONING LFA!"
                )
            return  # Do not forward LLDP — drop it

        # ── 4. MAC learning ───────────────────────────────────────
        self.mac_to_port[dpid][src_mac] = in_port

        # Determine output port
        if dst_mac in self.mac_to_port[dpid]:
            out_port = self.mac_to_port[dpid][dst_mac]
        else:
            out_port = ofproto.OFPP_FLOOD

        actions = [parser.OFPActionOutput(out_port)]

        # ── 5. Install flow rule (idle_timeout=10s) ───────────────
        if out_port != ofproto.OFPP_FLOOD:
            ip_pkt  = pkt.get_protocol(ipv4.ipv4)
            ip6_pkt = pkt.get_protocol(ipv6.ipv6)

            if ip_pkt:
                # IP packet — match on 5-tuple for LFA analysis
                tp_pkt = (pkt.get_protocol(tcp.tcp) or
                          pkt.get_protocol(udp.udp))

                if tp_pkt and hasattr(tp_pkt, 'src_port'):
                    # TCP/UDP — full 5-tuple match
                    proto_num = (6 if pkt.get_protocol(tcp.tcp)
                                 else 17)
                    match = parser.OFPMatch(
                        in_port=in_port,
                        eth_type=ether_types.ETH_TYPE_IP,
                        ipv4_src=ip_pkt.src,
                        ipv4_dst=ip_pkt.dst,
                        ip_proto=proto_num
                    )
                else:
                    # ICMP or other IP
                    match = parser.OFPMatch(
                        in_port=in_port,
                        eth_type=ether_types.ETH_TYPE_IP,
                        ipv4_src=ip_pkt.src,
                        ipv4_dst=ip_pkt.dst
                    )
            else:
                # Non-IP — match on MAC
                match = parser.OFPMatch(
                    in_port=in_port,
                    eth_dst=dst_mac,
                    eth_src=src_mac
                )

            # Install with IDLE_TIMEOUT=10s
            # Flow expires after 10s of inactivity
            # Controller then reinstalls default flow
            self._add_flow(
                datapath,
                priority=1,
                match=match,
                actions=actions,
                idle_timeout=self.IDLE_TIMEOUT,
                hard_timeout=self.HARD_TIMEOUT
            )

        # ── 6. Send packet out ────────────────────────────────────
        data = None
        if msg.buffer_id == ofproto.OFP_NO_BUFFER:
            data = msg.data

        out = parser.OFPPacketOut(
            datapath=datapath,
            buffer_id=msg.buffer_id,
            in_port=in_port,
            actions=actions,
            data=data
        )
        datapath.send_msg(out)

