#!/usr/bin/env python3
from mininet.topo import Topo
from mininet.net import Mininet
from mininet.node import RemoteController, OVSKernelSwitch
from mininet.link import TCLink
from mininet.cli import CLI
from mininet.log import setLogLevel

class FatTreeTopo(Topo):
    """
    Fat-Tree Topology with k=4
    - 4 core switches
    - 8 aggregation switches (2 per pod)
    - 8 edge switches      (2 per pod)
    - 16 hosts             (2 per edge switch)
    """
    def build(self, k=4):
        num_pods      = k
        num_core      = (k // 2) ** 2          # 4
        num_agg_per_pod  = k // 2              # 2
        num_edge_per_pod = k // 2              # 2
        num_host_per_edge = k // 2             # 2

        core_switches = []
        pod_switches  = []
        hosts         = []

        # ── Core switches ──────────────────────────────────────────────
        for i in range(num_core):
            sw = self.addSwitch(
                f'c{i+1}',
                cls=OVSKernelSwitch,
                protocols='OpenFlow13'
            )
            core_switches.append(sw)

        # ── Pods ───────────────────────────────────────────────────────
        host_count = 1
        for pod in range(num_pods):
            agg_switches  = []
            edge_switches = []

            # Aggregation switches
            for a in range(num_agg_per_pod):
                sw = self.addSwitch(
                    f'a{pod+1}{a+1}',
                    cls=OVSKernelSwitch,
                    protocols='OpenFlow13'
                )
                agg_switches.append(sw)

            # Edge switches + hosts
            for e in range(num_edge_per_pod):
                sw = self.addSwitch(
                    f'e{pod+1}{e+1}',
                    cls=OVSKernelSwitch,
                    protocols='OpenFlow13'
                )
                edge_switches.append(sw)

                for h in range(num_host_per_edge):
                    host = self.addHost(
                        f'h{host_count}',
                        ip=f'10.{pod}.{e}.{h+1}/24'
                    )
                    self.addLink(host, sw,
                                 bw=100, delay='1ms', loss=0)
                    host_count += 1

            # Edge ↔ Aggregation links
            for e_sw in edge_switches:
                for a_sw in agg_switches:
                    self.addLink(e_sw, a_sw,
                                 bw=1000, delay='1ms', loss=0)

            # Aggregation ↔ Core links
            for a_idx, a_sw in enumerate(agg_switches):
                for j in range(num_edge_per_pod):
                    core_idx = a_idx * num_edge_per_pod + j
                    self.addLink(a_sw, core_switches[core_idx],
                                 bw=10000, delay='1ms', loss=0)

            pod_switches.append((agg_switches, edge_switches))

topos = {'mytopo': (lambda: FatTreeTopo())}

if __name__ == '__main__':
    setLogLevel('info')
    topo = FatTreeTopo()
    net  = Mininet(
        topo=topo,
        controller=RemoteController('c0', ip='127.0.0.1', port=6633),
        switch=OVSKernelSwitch,
        link=TCLink,
        autoSetMacs=True
    )
    net.start()
    CLI(net)
    net.stop()

