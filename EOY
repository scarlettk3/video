    @set_ev_cls(ofp_event.EventOFPFlowRemoved, MAIN_DISPATCHER)
    def flow_removed_handler(self, ev):
        """
        Called when a flow expires (idle timeout = 10s).
        Reinstalls the default table-miss flow automatically.
        This implements your procedure:
        'when idle timeout expires, controller reinstalls default flows'
        """
        msg      = ev.msg
        datapath = msg.datapath
        dpid     = datapath.id
        reason   = msg.reason
        ofproto  = datapath.ofproto

        reason_str = {
            ofproto.OFPRR_IDLE_TIMEOUT : "IDLE_TIMEOUT",
            ofproto.OFPRR_HARD_TIMEOUT : "HARD_TIMEOUT",
            ofproto.OFPRR_DELETE       : "DELETE",
            ofproto.OFPRR_GROUP_DELETE : "GROUP_DELETE",
        }.get(reason, "UNKNOWN")

        if reason == ofproto.OFPRR_IDLE_TIMEOUT:
            logger.debug(
                f"[~] Flow expired (IDLE_TIMEOUT) on "
                f"dpid={dpid:#010x} | "
                f"pkts={msg.packet_count} | "
                f"bytes={msg.byte_count}"
            )
            # Reinstall default table-miss flow
            self._reinstall_default_flow(datapath)

    def _reinstall_default_flow(self, datapath):
        """
        Reinstall priority=0 table-miss flow after expiry.
        As per your procedure:
        'sudo ovs-ofctl add-flow {sw} priority=0,actions=CONTROLLER:65535'
        """
        ofproto = datapath.ofproto
        parser  = datapath.ofproto_parser
        match   = parser.OFPMatch()
        actions = [
            parser.OFPActionOutput(
                ofproto.OFPP_CONTROLLER,
                ofproto.OFPCML_NO_BUFFER
            )
        ]
        self._add_flow(
            datapath,
            priority=0,
            match=match,
            actions=actions,
            idle_timeout=0,
            hard_timeout=0
        )

